generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String    @id @default(uuid())
  full_name             String
  email                 String    @unique
  phone_number          String?   @unique
  password_hash         String
  profile_image         String?
  background_image      String?
  role_id               String
  role                  Role      @relation(fields: [role_id], references: [id])
  email_verified        Boolean   @default(false)
  phone_verified        Boolean   @default(false)
  account_status        String    @default("ACTIVE") // ACTIVE, INACTIVE, LOCKED, DELETED
  last_login_at         DateTime?
  failed_login_attempts Int       @default(0)
  locked_until          DateTime?
  
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt
  deleted_at            DateTime?
  created_by            String?
  updated_by            String?

  sessions              UserSession[]
  refresh_tokens        RefreshToken[]
  otps                  OtpVerification[]
  password_resets       PasswordReset[]
  activity_logs         ActivityLog[]
  support_tickets       SupportTicket[]

  @@map("users")
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique
  description String?
  permissions RolePermission[]
  users       User[]

  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  role_id       String
  permission_id String
  role          Role       @relation(fields: [role_id], references: [id])
  permission    Permission @relation(fields: [permission_id], references: [id])

  @@id([role_id, permission_id])
  @@map("role_permissions")
}

model RefreshToken {
  id          String   @id @default(uuid())
  user_id     String
  user        User     @relation(fields: [user_id], references: [id])
  token_hash  String
  expires_at  DateTime
  created_at  DateTime @default(now())

  @@map("refresh_tokens")
}

model UserSession {
  id                String    @id @default(uuid())
  user_id           String
  user              User      @relation(fields: [user_id], references: [id])
  refresh_token_hash String
  ip_address        String?
  device_name       String?
  browser           String?
  operating_system  String?
  location          String?
  expires_at        DateTime
  revoked_at        DateTime?
  created_at        DateTime  @default(now())

  @@map("user_sessions")
}

model OtpVerification {
  id          String    @id @default(uuid())
  user_id     String
  user        User      @relation(fields: [user_id], references: [id])
  otp_code    String
  type        String    // EMAIL_VERIFICATION, PHONE_VERIFICATION, LOGIN_OTP, PASSWORD_RESET
  expires_at  DateTime
  verified_at DateTime?
  created_at  DateTime  @default(now())

  @@map("otp_verifications")
}

model PasswordReset {
  id          String    @id @default(uuid())
  user_id     String
  user        User      @relation(fields: [user_id], references: [id])
  token_hash  String
  expires_at  DateTime
  used_at     DateTime?
  created_at  DateTime  @default(now())

  @@map("password_resets")
}

model ActivityLog {
  id          String   @id @default(uuid())
  user_id     String
  user        User     @relation(fields: [user_id], references: [id])
  action      String
  description String?
  ip_address  String?
  device_name String?
  created_at  DateTime @default(now())

  @@map("activity_logs")
}

// Business Models

model Mill {
  id          String     @id @default(uuid())
  name        String
  email       String?
  phone       String?
  address     String?
  status      String     @default("ACTIVE")
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt
  deleted_at  DateTime?
  customer_id String?
  customer    Customer?  @relation(fields: [customer_id], references: [id])
  serviceReports ServiceReport[]
  installationReports InstallationReport[]
  expenses    Expense[]
  supportTickets SupportTicket[]

  @@map("mills")
}

model ServiceCategory {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  status      String    @default("ACTIVE")
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?

  serviceReports ServiceReport[]

  @@map("service_categories")
}

model Customer {
  id          String    @id @default(uuid())
  name        String
  email       String?
  phone       String?
  address     String?
  status      String    @default("ACTIVE") // ACTIVE, INACTIVE
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?
  mills       Mill[]
  supportTickets SupportTicket[]
  stores      Store[]

  @@map("customers")
}

model ProductService {
  id          String    @id @default(uuid())
  name        String
  description String?
  category    String?
  price       Decimal   @default(0)
  status      String    @default("ACTIVE")
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?

  @@map("product_services")
}

model Technician {
  id          String    @id @default(uuid())
  full_name   String
  email       String?   @unique
  phone       String?   @unique
  status      String    @default("AVAILABLE") // AVAILABLE, ON_LEAVE, BUSY, INACTIVE
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?

  serviceReports ServiceReportTechnician[]
  installationReports InstallationReportTechnician[]
  expenses    ExpenseTechnician[]
  supportTickets SupportTicket[]
  stores      Store[]

  @@map("technicians")
}

model ServiceRecord {
  id            String    @id @default(uuid())
  mill_id       String
  technician_id String
  service_id    String
  visit_date    DateTime
  notes         String?
  status        String    @default("COMPLETED")
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  deleted_at    DateTime?

  @@map("service_records")
}

model Notification {
  id          String    @id @default(uuid())
  title       String
  message     String
  type        String    // PUSH, EMAIL, SMS, ANNOUNCEMENT
  status      String    @default("PENDING")
  created_at  DateTime  @default(now())

  @@map("notifications")
}

model SupportTicket {
  id                  String      @id @default(uuid())
  ticket_number       String?     @unique
  user_id             String?
  user                User?       @relation(fields: [user_id], references: [id])
  service_engineer_id String?
  service_engineer    Technician? @relation(fields: [service_engineer_id], references: [id])
  customer_id         String?
  customer            Customer?   @relation(fields: [customer_id], references: [id])
  mill_id             String?
  mill                Mill?       @relation(fields: [mill_id], references: [id])
  subject             String
  description         String
  status              String      @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, ESCALATED
  priority            String      @default("MEDIUM")
  created_at          DateTime    @default(now())
  updated_at          DateTime    @updatedAt

  @@index([ticket_number])
  @@index([service_engineer_id])
  @@index([customer_id])
  @@index([mill_id])
  @@map("support_tickets")
}

model Setting {
  id          String    @id @default(uuid())
  key         String    @unique
  value       String
  group       String    // GENERAL, APP, PAYMENT, NOTIFICATION, SECURITY
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  @@map("settings")
}

model ServiceReport {
  id                        String    @id @default(uuid())
  report_number             String    @unique
  service_category_id       String
  mill_id                   String
  place                     String
  mill_whatsapp_number      String
  mill_email                String?
  visit_date                DateTime
  visit_time                String
  call_registered_date      DateTime
  machine_model             String
  machine_mfg_date          DateTime?
  machine_installation_date DateTime?
  serial_or_frame_no        String
  authorized_person         String
  previous_visit_engineer   String?
  nature_of_complaint       String
  problem_observed          String?
  action_taken              String
  commodity                 String?
  contamination             String?
  output_capacity_per_hour  String?
  rejection_ratio           String?
  purity                    String?
  no_of_programs_set        Int?
  ac_provided               Boolean   @default(false)
  compressor_details        String?
  air_drier_details         String?
  line_filter_condition     String?
  machine_filter_condition  String?
  auto_drain_valve_working  Boolean   @default(false)
  engineer_remarks          String
  engineer_signature        String
  customer_remarks          String?
  customer_signature        String
  status                    String    @default("PENDING")
  created_at                DateTime  @default(now())
  updated_at                DateTime  @updatedAt
  deleted_at                DateTime?

  serviceCategory ServiceCategory @relation(fields: [service_category_id], references: [id])
  mill            Mill            @relation(fields: [mill_id], references: [id])
  technicians     ServiceReportTechnician[]

  @@map("service_reports")
}

model ServiceReportTechnician {
  service_report_id String
  technician_id     String
  serviceReport     ServiceReport @relation(fields: [service_report_id], references: [id])
  technician        Technician    @relation(fields: [technician_id], references: [id])

  @@id([service_report_id, technician_id])
  @@map("service_report_technicians")
}

model InstallationReport {
  id                        String    @id @default(uuid())
  report_number             String    @unique
  mill_id                   String
  place                     String
  mill_whatsapp_number      String
  mill_email                String?
  visit_date                DateTime
  visit_time                String
  call_registered_date      DateTime
  machine_model             String
  serial_or_frame_no        String
  authorized_person         String
  invoice_number            String?
  invoice_date              DateTime?
  warranty_start_date       DateTime?
  warranty_end_date         DateTime?
  commodity                 String?
  contamination             String?
  output_capacity_per_hour  String?
  rejection_ratio           String?
  purity                    String?
  no_of_programs_set        Int?
  ac_provided               Boolean   @default(false)
  compressor_details        String?
  air_drier_details         String?
  ground_earth_provided     Boolean   @default(false)
  ground_earth_value        Int?
  ground_earth_field        String?
  no_of_filters_installed   Int?
  oil_filter_condition      String?
  line_filter_condition     String?
  auto_drain_valve_working  Boolean   @default(false)
  engineer_remarks          String
  engineer_signature        String
  customer_remarks          String?
  customer_signature        String
  status                    String    @default("PENDING")
  created_at                DateTime  @default(now())
  updated_at                DateTime  @updatedAt
  deleted_at                DateTime?

  mill                      Mill            @relation(fields: [mill_id], references: [id])
  technicians               InstallationReportTechnician[]

  @@map("installation_reports")
}

model InstallationReportTechnician {
  installation_report_id String
  technician_id         String
  installationReport    InstallationReport @relation(fields: [installation_report_id], references: [id], onDelete: Cascade)
  technician            Technician         @relation(fields: [technician_id], references: [id])

  @@id([installation_report_id, technician_id])
  @@map("installation_report_technicians")
}

model Expense {
  id                  String              @id @default(uuid())
  expense_number      String              @unique
  mill_id             String?
  place               String?
  visit_date          DateTime
  visit_time          String
  expense_category_id String
  others              String?
  amount              Decimal             @default(0)
  expense_images      String[]            @default([])
  status              String              @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, CANCELLED
  created_at          DateTime            @default(now())
  updated_at          DateTime            @updatedAt
  deleted_at          DateTime?

  mill                Mill?               @relation(fields: [mill_id], references: [id])
  expenseCategory     ExpenseCategory     @relation(fields: [expense_category_id], references: [id])
  technicians         ExpenseTechnician[]

  @@map("expenses")
}

model ExpenseTechnician {
  expense_id    String
  technician_id String
  expense       Expense    @relation(fields: [expense_id], references: [id], onDelete: Cascade)
  technician    Technician @relation(fields: [technician_id], references: [id])

  @@id([expense_id, technician_id])
  @@map("expense_technicians")
}

model ExpenseCategory {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  status      String    @default("ACTIVE") // ACTIVE, INACTIVE
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?

  expenses    Expense[]

  @@map("expense_categories")
}

model Material {
  id          String         @id @default(uuid())
  name        String         @unique
  description String?
  status      String         @default("ACTIVE")
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt
  deleted_at  DateTime?
  stores      StoreMaterial[]

  @@map("materials")
}

model Store {
  id                  String         @id @default(uuid())
  service_engineer_id String
  service_engineer    Technician     @relation(fields: [service_engineer_id], references: [id])
  customer_id         String
  customer            Customer       @relation(fields: [customer_id], references: [id])
  quantity            Int
  warranty_status     String         // Under Warranty, Expired
  frame_number        String         @unique
  return_status       String         // Returned, Pending, Not Returned
  inflow_status       String         // Inflow, Outflow, Available, Damaged
  barcode             String?
  created_at          DateTime       @default(now())
  updated_at          DateTime       @updatedAt
  deleted_at          DateTime?
  materials           StoreMaterial[]

  @@map("stores")
}

model StoreMaterial {
  store_id    String
  material_id String
  store       Store    @relation(fields: [store_id], references: [id], onDelete: Cascade)
  material    Material @relation(fields: [material_id], references: [id])

  @@id([store_id, material_id])
  @@map("store_materials")
}

