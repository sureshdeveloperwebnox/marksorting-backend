generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String            @id @default(uuid())
  full_name             String
  email                 String            @unique
  phone_number          String?           @unique
  password_hash         String
  profile_image         String?
  background_image      String?
  role_id               String
  email_verified        Boolean           @default(false)
  phone_verified        Boolean           @default(false)
  account_status        String            @default("ACTIVE")
  last_login_at         DateTime?
  failed_login_attempts Int               @default(0)
  locked_until          DateTime?
  created_at            DateTime          @default(now())
  updated_at            DateTime          @updatedAt
  deleted_at            DateTime?
  created_by            String?
  updated_by            String?
  activity_logs         ActivityLog[]
  api_logs              ApiLog[]
  audit_trails          AuditTrail[]
  error_logs            ErrorLog[]
  notification_logs     NotificationLog[]
  notifications         Notification[]
  otps                  OtpVerification[]
  password_resets       PasswordReset[]
  push_tokens           PushToken[]
  refresh_tokens        RefreshToken[]
  security_logs         SecurityLog[]
  support_tickets       SupportTicket[]
  ticket_timelines      TicketTimeline[]
  sessions              UserSession[]
  role                  Role              @relation(fields: [role_id], references: [id])
  websocket_logs        WebSocketLog[]

  @@map("users")
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  created_at  DateTime         @default(now())
  updated_at  DateTime         @updatedAt
  permissions RolePermission[]
  users       User[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  role_id       String
  permission_id String
  permission    Permission @relation(fields: [permission_id], references: [id])
  role          Role       @relation(fields: [role_id], references: [id])

  @@id([role_id, permission_id])
  @@map("role_permissions")
}

model RefreshToken {
  id         String   @id @default(uuid())
  user_id    String
  token_hash String
  expires_at DateTime
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id])

  @@map("refresh_tokens")
}

model UserSession {
  id                 String    @id @default(uuid())
  user_id            String
  refresh_token_hash String
  ip_address         String?
  device_name        String?
  browser            String?
  operating_system   String?
  location           String?
  expires_at         DateTime
  revoked_at         DateTime?
  created_at         DateTime  @default(now())
  user               User      @relation(fields: [user_id], references: [id])

  @@map("user_sessions")
}

model OtpVerification {
  id          String    @id @default(uuid())
  user_id     String
  otp_code    String
  type        String
  expires_at  DateTime
  verified_at DateTime?
  created_at  DateTime  @default(now())
  user        User      @relation(fields: [user_id], references: [id])

  @@map("otp_verifications")
}

model PasswordReset {
  id         String    @id @default(uuid())
  user_id    String
  token_hash String
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())
  user       User      @relation(fields: [user_id], references: [id])

  @@map("password_resets")
}

model ActivityLog {
  id                String   @id @default(uuid())
  user_id           String
  action            String
  entity_type       String?
  entity_id         String?
  description       String
  metadata          Json?
  ip_address        String?
  user_agent        String?
  device_name       String?
  browser           String?
  os                String?
  correlation_id    String?  @db.Uuid
  request_id        String?  @db.Uuid
  session_id        String?
  execution_time_ms Int?
  archived          Boolean  @default(false)
  created_at        DateTime @default(now())
  user              User     @relation(fields: [user_id], references: [id])

  @@index([user_id, created_at])
  @@index([entity_type, entity_id])
  @@index([action, created_at])
  @@index([correlation_id])
  @@index([created_at])
  @@index([archived, created_at])
  @@map("activity_logs")
}

model Mill {
  id                  String               @id @default(uuid())
  name                String
  email               String?
  phone               String?
  address             String?
  status              String               @default("ACTIVE")
  created_at          DateTime             @default(now())
  updated_at          DateTime             @updatedAt
  deleted_at          DateTime?
  customer_id         String?
  ref_no              String?
  city                String?
  place               String?
  phone_2             String?
  phone_3             String?
  expenses            Expense[]
  installationReports InstallationReport[]
  masterMills         MasterMill[]
  customer            Customer?            @relation(fields: [customer_id], references: [id])
  serviceReports      ServiceReport[]
  supportTickets      SupportTicket[]

  @@map("mills")
}

model MasterMill {
  id                    String    @id @default(uuid())
  invoice_no            String
  invoice_date          DateTime?
  ref_no                String?
  mill_id               String?
  address               String?
  place                 String?
  state                 String?
  phone_no              String?
  mc_model              String?
  frame_no              String?
  warranty_years        Int?      @default(0)
  warranty_months       Int?      @default(0)
  installation_date     DateTime?
  warranty_closing_date DateTime?
  all_warranty          String?   @default("Non Warranty")
  amc_starting_date     DateTime?
  amc_period            Int?
  amc_particular        String?
  amc_closing_date      DateTime?
  amc_amount            Decimal?  @default(0)
  status                String    @default("ACTIVE")
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt
  deleted_at            DateTime?
  type                  String    @default("Installation")
  mill                  Mill?     @relation(fields: [mill_id], references: [id])

  @@index([mill_id])
  @@index([invoice_no])
  @@index([status, created_at])
  @@map("master_mills")
}

model ServiceCategory {
  id             String          @id @default(uuid())
  name           String          @unique
  description    String?
  status         String          @default("ACTIVE")
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt
  deleted_at     DateTime?
  serviceReports ServiceReport[]

  @@map("service_categories")
}

model Customer {
  id             String          @id @default(uuid())
  name           String
  email          String?
  phone          String?
  address        String?
  status         String          @default("ACTIVE")
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt
  deleted_at     DateTime?
  mills          Mill[]
  stores         Store[]
  supportTickets SupportTicket[]

  @@map("customers")
}

model ProductService {
  id          String    @id @default(uuid())
  name        String
  description String?
  category    String?
  price       Decimal   @default(0)
  status      String    @default("ACTIVE")
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?

  @@map("product_services")
}

model Technician {
  id                  String                         @id @default(uuid())
  full_name           String
  email               String?                        @unique
  phone               String?                        @unique
  status              String                         @default("AVAILABLE")
  created_at          DateTime                       @default(now())
  updated_at          DateTime                       @updatedAt
  deleted_at          DateTime?
  expenses            ExpenseTechnician[]
  installationReports InstallationReportTechnician[]
  serviceReports      ServiceReportTechnician[]
  stores              Store[]
  supportTickets      SupportTicket[]

  @@map("technicians")
}

model ServiceRecord {
  id            String    @id @default(uuid())
  mill_id       String
  technician_id String
  service_id    String
  visit_date    DateTime
  notes         String?
  status        String    @default("COMPLETED")
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  deleted_at    DateTime?

  @@map("service_records")
}

model Notification {
  id         String   @id @default(uuid())
  user_id    String?
  title      String
  message    String
  type       String
  status     String   @default("UNREAD")
  meta_data  Json?
  created_at DateTime @default(now())
  user       User?    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("notifications")
}

model PushToken {
  id          String   @id @default(uuid())
  user_id     String
  token       String
  device_type String   @default("WEB")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, token])
  @@index([user_id])
  @@map("push_tokens")
}

model SupportTicket {
  id                  String           @id @default(uuid())
  ticket_number       String?          @unique
  user_id             String?
  service_engineer_id String?
  customer_id         String?
  mill_id             String?
  subject             String
  description         String
  status              String           @default("OPEN")
  priority            String           @default("MEDIUM")
  created_at          DateTime         @default(now())
  updated_at          DateTime         @updatedAt
  customer            Customer?        @relation(fields: [customer_id], references: [id])
  mill                Mill?            @relation(fields: [mill_id], references: [id])
  service_engineer    Technician?      @relation(fields: [service_engineer_id], references: [id])
  user                User?            @relation(fields: [user_id], references: [id])
  timelines           TicketTimeline[]

  @@index([ticket_number])
  @@index([service_engineer_id])
  @@index([customer_id])
  @@index([mill_id])
  @@map("support_tickets")
}

model TicketTimeline {
  id                  String        @id @default(uuid())
  ticket_id           String
  user_id             String
  notes               String
  status              String?
  timeline_date       DateTime      @default(now())
  next_follow_up_date DateTime?
  created_at          DateTime      @default(now())
  updated_at          DateTime      @updatedAt
  ticket              SupportTicket @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  user                User          @relation(fields: [user_id], references: [id])

  @@index([ticket_id])
  @@index([user_id])
  @@map("ticket_timelines")
}

model Setting {
  id         String   @id @default(uuid())
  key        String   @unique
  value      String
  group      String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("settings")
}

model ServiceReport {
  id                        String                    @id @default(uuid())
  report_number             String                    @unique
  service_category_id       String
  mill_id                   String
  place                     String
  mill_whatsapp_number      String
  mill_email                String?
  visit_date                DateTime
  visit_time                String
  call_registered_date      DateTime
  machine_model             String
  machine_mfg_date          DateTime?
  machine_installation_date DateTime?
  serial_or_frame_no        String
  authorized_person         String
  previous_visit_engineer   String?
  nature_of_complaint       String
  problem_observed          String?
  action_taken              String
  commodity                 String?
  contamination             String?
  output_capacity_per_hour  String?
  rejection_ratio           String?
  purity                    String?
  no_of_programs_set        Int?
  ac_provided               Boolean                   @default(false)
  compressor_details        String?
  air_drier_details         String?
  line_filter_condition     String?
  machine_filter_condition  String?
  auto_drain_valve_working  Boolean                   @default(false)
  engineer_remarks          String
  engineer_signature        String
  customer_remarks          String?
  customer_signature        String
  status                    String                    @default("PENDING")
  created_at                DateTime                  @default(now())
  updated_at                DateTime                  @updatedAt
  deleted_at                DateTime?
  authorized_person_phone   String?
  expense_id                String?
  technicians               ServiceReportTechnician[]
  mill                      Mill                      @relation(fields: [mill_id], references: [id])
  serviceCategory           ServiceCategory           @relation(fields: [service_category_id], references: [id])
  expenses                  Expense[]

  @@map("service_reports")
}

model ServiceReportTechnician {
  service_report_id String
  technician_id     String
  serviceReport     ServiceReport @relation(fields: [service_report_id], references: [id])
  technician        Technician    @relation(fields: [technician_id], references: [id])

  @@id([service_report_id, technician_id])
  @@map("service_report_technicians")
}

model InstallationReport {
  id                       String                         @id @default(uuid())
  report_number            String                         @unique
  mill_id                  String
  place                    String
  mill_whatsapp_number     String
  mill_email               String?
  visit_date               DateTime
  visit_time               String
  call_registered_date     DateTime
  machine_model            String
  serial_or_frame_no       String
  authorized_person        String
  invoice_number           String?
  invoice_date             DateTime?
  warranty_start_date      DateTime?
  warranty_end_date        DateTime?
  commodity                String?
  contamination            String?
  output_capacity_per_hour String?
  rejection_ratio          String?
  purity                   String?
  no_of_programs_set       Int?
  ac_provided              Boolean                        @default(false)
  compressor_details       String?
  air_drier_details        String?
  ground_earth_provided    Boolean                        @default(false)
  running_channel_combination Int?
  running_channel_combination_value String?
  no_of_filters_installed  Int?
  oil_filter_condition     String?
  line_filter_condition    String?
  auto_drain_valve_working Boolean                        @default(false)
  engineer_remarks         String
  engineer_signature       String
  customer_remarks         String?
  customer_signature       String
  status                   String                         @default("PENDING")
  created_at               DateTime                       @default(now())
  updated_at               DateTime                       @updatedAt
  deleted_at               DateTime?
  authorized_person_phone  String?
  expense_id               String?
  technicians              InstallationReportTechnician[]
  mill                     Mill                           @relation(fields: [mill_id], references: [id])
  expenses                 Expense[]

  @@map("installation_reports")
}

model InstallationReportTechnician {
  installation_report_id String
  technician_id          String
  installationReport     InstallationReport @relation(fields: [installation_report_id], references: [id], onDelete: Cascade)
  technician             Technician         @relation(fields: [technician_id], references: [id])

  @@id([installation_report_id, technician_id])
  @@map("installation_report_technicians")
}

model Expense {
  id                  String              @id @default(uuid())
  expense_number      String              @unique
  expense_type        String              @default("MILL")
  report_type         String              @default("NONE")
  mill_id             String?
  place               String?
  visit_date          DateTime
  visit_time          String
  expense_category_id String?
  others              String?
  remarks             String?
  amount              Decimal             @default(0)
  admin_amount        Decimal             @default(0)
  expense_images      String[]            @default([])
  status              String              @default("PENDING")
  created_at          DateTime            @default(now())
  updated_at          DateTime            @updatedAt
  deleted_at          DateTime?
  technicians            ExpenseTechnician[]
  expenseCategory        ExpenseCategory?    @relation(fields: [expense_category_id], references: [id])
  mill                   Mill?               @relation(fields: [mill_id], references: [id])
  expense_items          ExpenseItem[]
  service_report_id      String?
  installation_report_id String?
  serviceReport          ServiceReport?      @relation(fields: [service_report_id], references: [id])
  installationReport     InstallationReport? @relation(fields: [installation_report_id], references: [id])

  @@map("expenses")
}

model ExpenseTechnician {
  expense_id    String
  technician_id String
  expense       Expense    @relation(fields: [expense_id], references: [id], onDelete: Cascade)
  technician    Technician @relation(fields: [technician_id], references: [id])

  @@id([expense_id, technician_id])
  @@map("expense_technicians")
}

model ExpenseCategory {
  id            String        @id @default(uuid())
  name          String        @unique
  description   String?
  status        String        @default("ACTIVE")
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt
  deleted_at    DateTime?
  expenses      Expense[]
  expense_items ExpenseItem[]

  @@map("expense_categories")
}

model ExpenseItem {
  id                  String          @id @default(uuid())
  expense_id          String
  expense_category_id String
  amount              Decimal         @default(0)
  admin_amount        Decimal         @default(0)
  remarks             String?
  admin_remarks       String?
  expense_images      String[]        @default([])
  created_at          DateTime        @default(now())
  updated_at          DateTime        @updatedAt
  expense             Expense         @relation(fields: [expense_id], references: [id], onDelete: Cascade)
  expenseCategory     ExpenseCategory @relation(fields: [expense_category_id], references: [id])

  @@unique([expense_id, expense_category_id])
  @@map("expense_items")
}

model Material {
  id          String          @id @default(uuid())
  name        String          @unique
  description String?
  status      String          @default("ACTIVE")
  created_at  DateTime        @default(now())
  updated_at  DateTime        @updatedAt
  deleted_at  DateTime?
  stores      StoreMaterial[]

  @@map("materials")
}

model Store {
  id                  String          @id @default(uuid())
  service_engineer_id String
  customer_id         String
  quantity            Int
  warranty_status     String
  frame_number        String          @unique
  return_status       String
  inflow_status       String
  barcode             String?
  provider_name       String?
  invoice_number      String?
  remarks             String?
  created_at          DateTime        @default(now())
  updated_at          DateTime        @updatedAt
  deleted_at          DateTime?
  materials           StoreMaterial[]
  customer            Customer        @relation(fields: [customer_id], references: [id])
  service_engineer    Technician      @relation(fields: [service_engineer_id], references: [id])

  @@map("stores")
}

model StoreMaterial {
  store_id    String
  material_id String
  quantity    Int      @default(1)
  material    Material @relation(fields: [material_id], references: [id])
  store       Store    @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@id([store_id, material_id])
  @@map("store_materials")
}

model AuditTrail {
  id             String   @id @default(uuid())
  user_id        String
  action         String
  entity_type    String
  entity_id      String
  before_data    Json?
  after_data     Json?
  changed_fields Json?
  description    String?
  reason         String?
  ip_address     String?
  user_agent     String?
  correlation_id String?  @db.Uuid
  archived       Boolean  @default(false)
  created_at     DateTime @default(now())
  user           User     @relation(fields: [user_id], references: [id])

  @@index([entity_type, entity_id, created_at])
  @@index([user_id, created_at])
  @@index([correlation_id])
  @@index([archived, created_at])
  @@map("audit_trails")
}

model SecurityLog {
  id                 String   @id @default(uuid())
  user_id            String?
  event_type         String
  severity           String
  description        String
  email_attempted    String?
  auth_method        String?
  mfa_used           Boolean  @default(false)
  failure_reason     String?
  ip_address         String
  user_agent         String?
  device_fingerprint String?
  geolocation        Json?
  correlation_id     String?  @db.Uuid
  session_id         String?
  risk_score         Int?
  is_suspicious      Boolean  @default(false)
  created_at         DateTime @default(now())
  user               User?    @relation(fields: [user_id], references: [id])

  @@index([user_id, created_at])
  @@index([event_type, created_at])
  @@index([ip_address, created_at])
  @@index([is_suspicious])
  @@index([created_at])
  @@map("security_logs")
}

model ApiLog {
  id                   String   @id @default(uuid())
  method               String
  path                 String
  query_params         Json?
  request_body         Json?
  request_headers      Json?
  status_code          Int?
  response_body        Json?
  response_time_ms     Int?
  user_id              String?
  api_key_id           String?
  rate_limit_hit       Boolean  @default(false)
  rate_limit_remaining Int?
  ip_address           String?
  correlation_id       String?  @db.Uuid
  created_at           DateTime @default(now())
  user                 User?    @relation(fields: [user_id], references: [id])

  @@index([user_id, created_at])
  @@index([path, created_at])
  @@index([status_code, created_at])
  @@index([created_at])
  @@map("api_logs")
}

model ErrorLog {
  id               String    @id @default(uuid())
  error_type       String
  error_code       String?
  message          String
  stack_trace      String?
  user_id          String?
  correlation_id   String?   @db.Uuid
  method           String?
  path             String?
  request_body     Json?
  is_resolved      Boolean   @default(false)
  resolved_by      String?
  resolved_at      DateTime?
  resolution_notes String?
  alert_sent       Boolean   @default(false)
  severity         String    @default("ERROR")
  created_at       DateTime  @default(now())
  user             User?     @relation(fields: [user_id], references: [id])

  @@index([is_resolved])
  @@index([error_type, created_at])
  @@index([correlation_id])
  @@index([created_at])
  @@map("error_logs")
}

model JobLog {
  id            String    @id @default(uuid())
  job_id        String
  job_name      String
  queue_name    String
  status        String
  started_at    DateTime?
  completed_at  DateTime?
  duration_ms   Int?
  payload       Json?
  result        Json?
  error_message String?
  retry_count   Int       @default(0)
  worker_id     String?
  created_at    DateTime  @default(now())

  @@index([status, created_at])
  @@index([job_name, created_at])
  @@index([status])
  @@index([created_at])
  @@map("job_logs")
}

model NotificationLog {
  id                  String    @id @default(uuid())
  user_id             String?
  notification_type   String
  channel             String
  title_hash          String?
  content_length      Int?
  status              String
  provider            String?
  provider_message_id String?
  sent_at             DateTime?
  delivered_at        DateTime?
  opened_at           DateTime?
  error_message       String?
  created_at          DateTime  @default(now())
  user                User?     @relation(fields: [user_id], references: [id])

  @@index([user_id, created_at])
  @@index([status, created_at])
  @@index([created_at])
  @@map("notification_logs")
}

model WebSocketLog {
  id                 String    @id @default(uuid())
  socket_id          String
  user_id            String?
  event_type         String
  room               String?
  event_name         String?
  payload_size_bytes Int?
  ip_address         String?
  connected_at       DateTime?
  disconnected_at    DateTime?
  duration_seconds   Int?
  created_at         DateTime  @default(now())
  user               User?     @relation(fields: [user_id], references: [id])

  @@index([user_id, created_at])
  @@index([socket_id, created_at])
  @@index([created_at])
  @@map("websocket_logs")
}

model LogRetentionPolicy {
  id                 String    @id @default(uuid())
  log_type           String    @unique
  retention_days     Int
  archive_enabled    Boolean   @default(true)
  archive_after_days Int?
  delete_after_days  Int?
  last_cleanup_at    DateTime?
  created_at         DateTime  @default(now())

  @@map("log_retention_policies")
}
